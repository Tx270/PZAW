<div class="container mt-4" style="max-width: 480px;">
  <h2 class="mb-4">Profile</h2>

  <div class="card bg-dark text-white border-secondary">
    <div class="card-body d-flex align-items-center gap-3">
      <img src="/img/avatar.png" alt="Avatar" width="64" height="64"
           class="rounded-circle" style="object-fit: cover;">
      <div>
        <h5 class="card-title mb-0"><%= user.username %></h5>
        <small class="text">Member since <%= new Date(Number(user.created_at)).toLocaleDateString() %></small>
      </div>
    </div>
  </div>

  <a href="/auth/logout" class="btn btn-outline-danger mt-3">Log out</a>
</div>
